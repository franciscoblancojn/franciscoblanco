---
import { sanitizeVTName } from "../utils/sanitizeVTName";

interface Props {
  title: string;
  img?: string;
  single?: boolean;
  imgReplaceTitle?: boolean;
  date?: string;
  list: string[];
  url?: string;
}

const { title, img = "", single = false, imgReplaceTitle = false, date = "", list, url = "" } = Astro.props;
const vtName = sanitizeVTName(title);

let titleContent = `<strong>${title}</strong>`;
if (img && !imgReplaceTitle) {
  titleContent = `<img src="${img}" alt="${title}" class="img-textList ${!single ? "img-textList-small" : ""}"/><strong>${title}</strong>`;
} else if (img && imgReplaceTitle) {
  titleContent = `<img src="${img}" alt="${title}" class="img-textList ${!single ? "img-textList-small" : ""}"/>`;
}
if (url) {
  titleContent = `<a href="${url}" style="display:flex;align-items:center"><i class="fa fa-link" style="margin-right:10px"></i>${titleContent}</a>`;
}
---
<style set:html={`[data-vt="${vtName}"]{view-transition-name:${vtName}}`}></style>
<div data-vt={vtName} class="textList">
  <div id={vtName} class="has"></div>
  <div class:list={["textList-title", { "textList-title-single": single }]}>
    <Fragment set:html={titleContent}/>
  </div>
  <div class="date">{date}</div>
  {list.length > 0 && (
    <ul>
      {list.map((item) => (
        <li><Fragment set:html={item}/></li>
      ))}
    </ul>
  )}
</div>
